# Скопируй этот файл в .env и заполни своими значениями:
#   cp .env.example .env  (Linux/Mac)
#   copy .env.example .env  (Windows)

# База данных PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dacha

# Redis
REDIS_URL=redis://localhost:6379

# JWT — сгенерируй свой ключ командой:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=замени_на_свой_ключ
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS — origins через запятую, без пробелов
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000